{% extends "layout.twig" %}

{% block content %}
    <div class="layout-two-col">
        <div>
            <div class="card card-block">
                <div class="card-header2">
                    <div>
                        历史记录
                        <div class="section-desc">按 session 聚合展示，支持整会话收藏、删除、继续提问</div>
                    </div>
                    <div class="card-tools">
                        <button class="btn btn-sm btn-outline-secondary" data-box-toggle="history_page_panel">折叠</button>
                    </div>
                </div>
                <div class="card-body" id="history_page_panel">
                    <div class="row g-2">
                        <div class="col-md-4">
                            <label class="compact-label">项目</label>
                            <select id="history_project_name" class="form-select form-select-sm">
                                <option value="">全部项目</option>
                                {% for p in projects %}
                                    <option value="{{ p }}">{{ p }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="compact-label">关键词</label>
                            <input id="history_keyword_page" type="text" class="form-control form-control-sm" placeholder="问题/回答关键词">
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button class="btn btn-outline-secondary btn-sm w-100" data-action="history-page-search">搜索</button>
                        </div>
                    </div>

                    <div class="mt-3">
                        <div id="history_page_list" class="doc-box history-box"></div>
                    </div>

                    <div class="row g-2 mt-2">
                        <div class="col-md-4">
                            <button id="history_page_prev_btn" class="btn btn-outline-secondary btn-sm w-100" data-action="history-page-prev">上一页</button>
                        </div>
                        <div class="col-md-4 d-flex align-items-center justify-content-center">
                            <div class="mini-meta" id="history_page_pager_info">第 1 / 1 页</div>
                        </div>
                        <div class="col-md-4">
                            <button id="history_page_next_btn" class="btn btn-outline-secondary btn-sm w-100" data-action="history-page-next">下一页</button>
                        </div>
                    </div>

                    <div class="mt-2 d-flex justify-content-end gap-2">
                        <button class="btn btn-outline-danger btn-sm" data-action="history-page-clear-project">删除当前项目历史</button>
                        <button class="btn btn-danger btn-sm" data-action="history-page-clear-all">删除全部历史</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="layout-right-stack">
            <div class="card card-block">
                <div class="card-header2">
                    <div>
                        历史详情
                        <div class="section-desc">点击左侧项查看完整会话</div>
                    </div>
                    <div class="card-tools">
                        <button class="btn btn-sm btn-outline-secondary" data-box-toggle="history_page_detail">折叠</button>
                    </div>
                </div>
                <div class="card-body">
                    <div id="history_page_detail" class="doc-box detail-box"></div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}