{% extends "layout.twig" %}

{% block content %}
    <div class="layout-two-col">
        <div>
            <div class="card card-block">
                <div class="card-header2">
                    <div>
                        项目管理
                        <div class="section-desc">完全基于 Python /api/tasks/* 新接口</div>
                    </div>
                    <div class="card-tools">
                        <div class="card-loading" id="admin_loading"><span class="dot"></span><span class="text">运行中...</span></div>
                        <button class="btn btn-sm btn-outline-secondary" data-box-toggle="admin_params_panel">折叠</button>
                    </div>
                </div>

                <div class="card-body" id="admin_params_panel">
                    <div class="mb-3">
                        <label class="compact-label">项目</label>
                        <select id="admin_project_name" class="form-select form-select-sm">
                            {% for p in projects %}
                                <option value="{{ p }}">{{ p }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="row g-2">
                        <div class="col-md-6">
                            <label class="compact-label">Mode</label>
                            <select id="admin_mode" class="form-select form-select-sm">
                                <option value="api">api</option>
                                <option value="impl">impl</option>
                                <option value="method_only">method_only</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="compact-label">Debug</label>
                            <select id="admin_debug" class="form-select form-select-sm">
                                <option value="1" selected>开启</option>
                                <option value="0">关闭</option>
                            </select>
                        </div>
                    </div>

                    <div class="row g-2 mt-1">
                        <div class="col-md-6">
                            <label class="compact-label">Embedding 模型</label>
                            <select id="admin_embed_model" class="form-select form-select-sm">
                                {% for m in embed_model_choices %}
                                    <option value="{{ m }}" {% if m == default_embed_model %}selected{% endif %}>{{ m }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="compact-label">Chat 模型</label>
                            <select id="admin_chat_model" class="form-select form-select-sm">
                                {% for m in chat_model_choices %}
                                    <option value="{{ m }}" {% if m == default_chat_model %}selected{% endif %}>{{ m }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>

                    <div class="row g-2 mt-3">
                        <div class="col-md-4">
                            <button class="btn btn-success btn-sm w-100" data-action="admin-task-full">一键全量创建</button>
                        </div>
                        <div class="col-md-4">
                            <button class="btn btn-outline-secondary btn-sm w-100" data-action="admin-task-incremental">一键增量创建</button>
                        </div>
                        <div class="col-md-4">
                            <button class="btn btn-danger btn-sm w-100" data-action="admin-task-reset">一键清空</button>
                        </div>
                    </div>

                    <div class="mini-meta mt-2">
                        一键清空会删除当前项目的索引、辅助索引、summary、增量状态和任务记录，并清理该项目排队中的其它任务；不会删除历史问答记录，历史请到“历史”页单独删除。
                    </div>

                    <div class="mt-3">
                        <label class="compact-label">任务列表</label>
                        <div id="task_list" class="doc-box history-box"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="layout-right-stack">
            <div class="card card-block">
                <div class="card-header2">
                    <div>
                        执行结果
                        <div class="section-desc">任务完成后的摘要</div>
                    </div>
                    <div class="card-tools">
                        <button class="btn btn-sm btn-outline-secondary" data-box-toggle="admin_result">折叠</button>
                    </div>
                </div>
                <div class="p-3">
                    <div id="admin_task_progress_panel"></div>
                </div>
                <div class="card-body">
                    <div id="admin_result" class="doc-box"></div>
                </div>
            </div>

            <div class="card card-block mt-3">
                <div class="card-header2">
                    <div>
                        实时进度
                        <div class="section-desc">任务日志与状态流，通常首行会显示对应的 Python 调用命令</div>
                    </div>
                    <div class="card-tools">
                        <button class="btn btn-sm btn-outline-secondary" data-box-toggle="admin_progress">折叠</button>
                    </div>
                </div>
                <div class="card-body">
                    <div id="admin_progress" class="doc-box admin-progress-box"></div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}